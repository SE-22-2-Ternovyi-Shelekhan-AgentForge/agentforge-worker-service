# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
SESSIONS_QUEUE=agent-sessions-queue
EVENTS_QUEUE=agent-events-queue
RESULTS_QUEUE=agent-results-queue
ERRORS_QUEUE=agent-errors-queue

# LLM provider
DEFAULT_PROVIDER=ollama
SUPERVISOR_PROVIDER=ollama
DEFAULT_MODEL=qwen2.5:7b
DEFAULT_TEMPERATURE=0.2
SUPERVISOR_MODEL=qwen2.5:7b
LLM_TIMEOUT_SECONDS=180

# Ollama (local LLM)
OLLAMA_BASE_URL=http://ollama:11434

# OpenAI (only used when provider=openai)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# Worker
LOG_LEVEL=INFO
PREFETCH_COUNT=1
WORKSPACE_PATH=/workspace
